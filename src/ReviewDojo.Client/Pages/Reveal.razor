@page "/reveal/{SessionId:int}/{Ordinal:int}"
@inject NavigationManager Nav
@using ReviewDojo.Client.Services

@if (r is null)
{
  <div class="panel narrow">No reveal data. <a href="/">Start a new session.</a></div>
}
else
{
  <div class="narrow">
    <div class="page-head">
      <div class="eyebrow">Result · diff @(Ordinal + 1) of 5</div>
      <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap">
        <h1 style="margin:.2rem 0">Revealed</h1>
        <span class="verdict-badge @(r.Score.VerdictCorrect ? "ok" : "no")">
          @(r.Score.VerdictCorrect ? "✓ Verdict correct" : "✗ Verdict wrong")
        </span>
      </div>
    </div>

    <div class="tally">
      <span class="hit">Hits <b>@r.Score.Hits</b></span>
      <span class="miss">Missed <b>@r.Score.Misses</b></span>
      <span class="fp">False positives <b>@r.Score.FalsePositives</b></span>
    </div>

    <div class="metrics-grid">
      <div class="stat brand"><div class="k">Recall</div><div class="v">@r.Score.Recall.ToString("P0")</div></div>
      <div class="stat brand"><div class="k">Precision</div><div class="v">@r.Score.Precision.ToString("P0")</div></div>
      <div class="stat"><div class="k">Sev-weighted recall</div><div class="v">@r.Score.SeverityWeightedRecall.ToString("P0")</div></div>
      <div class="stat @(r.Score.FalsePositiveRate > 0 ? "bad" : "good")"><div class="k">False-positive rate</div><div class="v">@r.Score.FalsePositiveRate.ToString("P0")</div></div>
      <div class="stat"><div class="k">Time</div><div class="v">@(r.Score.TimeMs / 1000)s</div></div>
    </div>

    <div class="section-title">
      <h3>Seeded bugs</h3>
      <span class="count-badge">@r.Manifest.Count ground-truth</span>
    </div>

    @if (r.Manifest.Count == 0)
    {
      <div class="clean-banner">◇ This was a <strong>&nbsp;clean diff&nbsp;</strong> — there were no seeded bugs. Approving was the correct call.</div>
    }
    else
    {
      <ul class="manifest">
        @foreach (var b in r.Manifest)
        {
          <li>
            <div class="row1">
              <span class="loc">@b.FilePath:@b.LineStart</span>
              <span class="cat-tag cat-@b.Category">@b.Category</span>
              <span class="sev sev-@b.Severity">@b.Severity</span>
            </div>
            <div class="desc">@b.Description</div>
          </li>
        }
      </ul>
    }

    <div class="reveal-actions">
      @if (Ordinal + 1 < 5)
      {
        <button class="btn btn-primary btn-lg" @onclick="Next">Next diff →</button>
      }
      else
      {
        <button class="btn btn-primary btn-lg" @onclick='() => Nav.NavigateTo("/stats")'>See cumulative stats →</button>
      }
    </div>
  </div>
}

@code {
    [Parameter] public int SessionId { get; set; }
    [Parameter] public int Ordinal { get; set; }
    RevealDto? r;
    protected override void OnInitialized() => r = RevealCache.Last;
    void Next() => Nav.NavigateTo($"/review/{SessionId}/{Ordinal + 1}");
}
