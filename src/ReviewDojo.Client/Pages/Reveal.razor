@page "/reveal/{SessionId:int}/{Ordinal:int}"
@inject NavigationManager Nav
@using ReviewDojo.Client.Services

@if (r is null)
{
  <div class="panel narrow">No reveal data. <a href="/">Start a new session.</a></div>
}
else
{
  <div class="narrow">
    <div class="page-head">
      <div class="eyebrow">Result · diff @(Ordinal + 1) of 5</div>
      <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap">
        <h1 style="margin:.2rem 0">Revealed</h1>
        <span class="verdict-badge @(r.Score.VerdictCorrect ? "ok" : "no")">
          @(r.Score.VerdictCorrect ? "✓ Verdict correct" : "✗ Verdict wrong")
        </span>
      </div>
    </div>

    <div class="tally">
      <span class="hit">Hits <b>@r.Score.Hits</b></span>
      <span class="miss">Missed <b>@r.Score.Misses</b></span>
      <span class="fp">False positives <b>@r.Score.FalsePositives</b></span>
    </div>

    <div class="metrics-grid">
      <div class="stat brand"><div class="k">Recall</div><div class="v">@r.Score.Recall.ToString("P0")</div></div>
      <div class="stat brand"><div class="k">Precision</div><div class="v">@r.Score.Precision.ToString("P0")</div></div>
      <div class="stat"><div class="k">Sev-weighted recall</div><div class="v">@r.Score.SeverityWeightedRecall.ToString("P0")</div></div>
      <div class="stat @(r.Score.FalsePositiveRate > 0 ? "bad" : "good")"><div class="k">False-positive rate</div><div class="v">@r.Score.FalsePositiveRate.ToString("P0")</div></div>
      <div class="stat"><div class="k">Time</div><div class="v">@(r.Score.TimeMs / 1000)s</div></div>
    </div>

    <div class="section-title"><h3>How your review did</h3></div>

    @{
      var hits   = r.Matches.Where(m => m.BugFile != null && m.FindingFile != null).ToList();
      var fps    = r.Matches.Where(m => m.BugFile == null && m.FindingFile != null).ToList();
      var misses = r.Matches.Where(m => m.BugFile != null && m.FindingFile == null).ToList();
    }

    @if (hits.Count == 0 && fps.Count == 0 && misses.Count == 0)
    {
      <div class="clean-banner">◇ Clean diff — no seeded bugs, and you flagged nothing. Approving was the correct call.</div>
    }

    @if (hits.Count > 0)
    {
      <div class="sub-head"><h4>✓ You caught</h4><span class="n">@hits.Count</span></div>
      <ul class="rev-list">
        @foreach (var m in hits)
        {
          var bug = Bug(m); var find = Find(m);
          <li class="caught">
            <div class="row1">
              <span class="outcome ok">HIT</span>
              <span class="loc">@m.FindingFile:@m.FindingLine</span>
              @if (bug is not null)
              {
                <span class="cat-tag cat-@bug.Category">@bug.Category</span>
                <span class="sev sev-@bug.Severity">@bug.Severity</span>
              }
              @if (m.Credit < 1.0)
              {
                <span class="note">½ credit — right spot, wrong category@(find is not null && bug is not null ? $" (you said {find.Category}, it was {bug.Category})" : "")</span>
              }
            </div>
            @if (bug is not null) { <div class="desc">@bug.Description</div> }
            @if (find is not null && !string.IsNullOrWhiteSpace(find.Comment)) { <div class="note-you">Your note: “@find.Comment”</div> }
          </li>
        }
      </ul>
    }

    @if (fps.Count > 0)
    {
      <div class="sub-head"><h4>✗ False positives</h4><span class="n">@fps.Count</span></div>
      <ul class="rev-list">
        @foreach (var m in fps)
        {
          var find = Find(m);
          <li class="fp-item">
            <div class="row1">
              <span class="outcome warn">NOT A BUG</span>
              <span class="loc">@m.FindingFile:@m.FindingLine</span>
              @if (find is not null) { <span class="cat-tag cat-@find.Category">@find.Category</span> }
            </div>
            <div class="desc">No seeded bug here — nothing was actually wrong at this line.</div>
            @if (find is not null && !string.IsNullOrWhiteSpace(find.Comment)) { <div class="note-you">Your note: “@find.Comment”</div> }
          </li>
        }
      </ul>
    }

    @if (misses.Count > 0)
    {
      <div class="sub-head"><h4>⚠ You missed</h4><span class="n">@misses.Count</span></div>
      <ul class="rev-list">
        @foreach (var m in misses)
        {
          var bug = Bug(m);
          <li class="miss-item">
            <div class="row1">
              <span class="outcome bad">MISSED</span>
              <span class="loc">@(bug?.FilePath):@(bug?.LineStart)</span>
              @if (bug is not null)
              {
                <span class="cat-tag cat-@bug.Category">@bug.Category</span>
                <span class="sev sev-@bug.Severity">@bug.Severity</span>
              }
            </div>
            @if (bug is not null) { <div class="desc">@bug.Description</div> }
          </li>
        }
      </ul>
    }

    <div class="reveal-actions">
      @if (Ordinal + 1 < 5)
      {
        <button class="btn btn-primary btn-lg" @onclick="Next">Next diff →</button>
      }
      else
      {
        <button class="btn btn-primary btn-lg" @onclick='() => Nav.NavigateTo("/stats")'>See cumulative stats →</button>
      }
    </div>
  </div>
}

@code {
    [Parameter] public int SessionId { get; set; }
    [Parameter] public int Ordinal { get; set; }
    RevealDto? r;

    protected override void OnInitialized() => r = RevealCache.Last;

    ManifestBugDto? Bug(MatchDto m) => r!.Manifest.FirstOrDefault(b => b.FilePath == m.BugFile && b.LineStart == m.BugLine);
    FindingDto? Find(MatchDto m) => RevealCache.Findings?.FirstOrDefault(f => f.FilePath == m.FindingFile && f.Line == m.FindingLine);

    void Next() => Nav.NavigateTo($"/review/{SessionId}/{Ordinal + 1}");
}
