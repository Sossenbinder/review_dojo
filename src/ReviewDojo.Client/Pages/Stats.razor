@page "/stats"
@inject ReviewDojo.Client.Services.ApiClient Api
@using ReviewDojo.Client.Services

<div class="narrow">
  @if (loading)
  {
    <div class="panel" style="color:var(--muted)">Loading stats…</div>
  }
  else if (s is null || s.TotalScored == 0)
  {
    <div class="page-head"><div class="eyebrow">Progress</div><h1 style="margin:.2rem 0">Cumulative stats</h1></div>
    <div class="panel">No completed diffs yet. <a href="/">Start a session</a> to build your track record.</div>
  }
  else
  {
    <div class="page-head">
      <div class="eyebrow">Progress · @s.TotalScored diffs reviewed</div>
      <h1 style="margin:.2rem 0">Your track record</h1>
    </div>

    <div class="metrics-grid">
      <div class="stat brand"><div class="k">Mean recall</div><div class="v">@s.MeanRecall.ToString("P0")</div></div>
      <div class="stat brand"><div class="k">Mean precision</div><div class="v">@s.MeanPrecision.ToString("P0")</div></div>
      <div class="stat @(s.MeanFpRate > 0 ? "bad" : "good")"><div class="k">Mean FP rate</div><div class="v">@s.MeanFpRate.ToString("P0")</div></div>
      <div class="stat"><div class="k">Median time</div><div class="v">@((s.MedianTimeMs / 1000).ToString("0"))s</div></div>
    </div>

    <div class="section-title"><h3>Calibration</h3></div>
    <div class="metrics-grid">
      <div class="stat good"><div class="k">Clean-diff approvals</div><div class="v">@s.CleanApprovalRate.ToString("P0")</div></div>
      <div class="stat good"><div class="k">Seeded-diff rejections</div><div class="v">@s.SeededRejectionRate.ToString("P0")</div></div>
    </div>

    <div class="section-title"><h3>Recall by bug category</h3></div>
    @if (s.PerCategoryRecall.Count == 0)
    {
      <p class="empty">No seeded bugs scored yet.</p>
    }
    else
    {
      <div class="cat-bars">
        @foreach (var kv in s.PerCategoryRecall)
        {
          <div class="cat-bar">
            <span class="name"><span class="cat-tag cat-@kv.Key">@kv.Key</span></span>
            <span class="track"><span class="fill" style="width:@((kv.Value * 100).ToString("0"))%"></span></span>
            <span class="pct">@kv.Value.ToString("P0")</span>
          </div>
        }
      </div>
    }

    <p style="margin-top:28px"><a href="/">Start another session →</a></p>
  }
</div>

@code {
    StatsDto? s; bool loading = true;
    protected override async Task OnInitializedAsync()
    {
        try { s = await Api.Stats(); }
        finally { loading = false; }
    }
}
