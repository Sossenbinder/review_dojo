@page "/"
@inject ReviewDojo.Client.Services.ApiClient Api
@inject NavigationManager Nav

<div class="hero">
    <div class="eyebrow">Deliberate practice</div>
    <h1>Sharpen your code review.</h1>
    <p class="lede">
        An agent generates realistic diffs against a real codebase with a hidden number of
        seeded bugs — sometimes zero. Spot them, submit a verdict, and get scored against ground truth.
    </p>

    <div class="panel start-card">
        <div class="field">
            <label>Target repository path</label>
            <input @bind="repo" @bind:event="oninput" placeholder="/path/to/a/local/source/repo" />
            <p class="hint">Any local folder with source files — read-only, its code is never executed.</p>
        </div>

        <div class="field-row">
            <div class="field" style="flex:0 0 200px">
                <label>Difficulty</label>
                <select @bind="tier">
                    <option value="Easy">Easy — obvious, mechanical</option>
                    <option value="Medium">Medium — edge cases</option>
                    <option value="Hard">Hard — contextual, subtle</option>
                </select>
            </div>
            <button class="btn btn-primary btn-lg" disabled="@(string.IsNullOrWhiteSpace(repo) || busy)" @onclick="Start">
                @(busy ? "Generating…" : "Start session · 5 diffs")
            </button>
        </div>

        @if (error is not null) { <p class="error">@error</p> }
    </div>
</div>

@code {
    string repo = ""; string tier = "Medium"; bool busy; string? error;
    async Task Start()
    {
        busy = true; error = null;
        try
        {
            var id = await Api.CreateSession(new(repo, tier, 0.2, null));
            Nav.NavigateTo($"/review/{id}/0");
        }
        catch (Exception ex) { error = ex.Message; busy = false; }
    }
}
